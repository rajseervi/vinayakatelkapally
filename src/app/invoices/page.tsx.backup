        </TabPanel>

        <TabPanel value={activeTab} index={3}>
          <Fade in timeout={1000}>
            <Paper 
              elevation={0}
              sx={{ 
                background: `linear-gradient(135deg, ${alpha(theme.palette.info.main, 0.05)} 0%, ${alpha(theme.palette.primary.main, 0.03)} 100%)`,
                border: `1px solid ${alpha(theme.palette.info.main, 0.1)}`,
                borderRadius: 3,
                p: 6,
                textAlign: 'center',
                position: 'relative',
                overflow: 'hidden'
              }}
            >
              <Box sx={{ position: 'relative', zIndex: 1 }}>
                <Zoom in timeout={1200}>
                  <Avatar 
                    sx={{ 
                      width: 120, 
                      height: 120, 
                      bgcolor: alpha(theme.palette.info.main, 0.1),
                      color: theme.palette.info.main,
                      mx: 'auto',
                      mb: 3,
                      boxShadow: `0 8px 25px ${alpha(theme.palette.info.main, 0.2)}`
                    }}
                  >
                    <AnalyticsIcon sx={{ fontSize: 60 }} />
                  </Avatar>
                </Zoom>
                
                <Typography variant="h3" fontWeight="bold" gutterBottom>
                  Advanced Analytics
                </Typography>
                <Typography variant="h6" color="text.secondary" sx={{ mb: 4, maxWidth: 600, mx: 'auto' }}>
                  Comprehensive reporting and insights dashboard with real-time data visualization, 
                  trend analysis, and business intelligence features
                </Typography>
                
                <Stack direction="row" spacing={2} justifyContent="center" sx={{ mb: 4 }}>
                  <Chip 
                    icon={<SparklesIcon />} 
                    label="AI-Powered Insights" 
                    color="info" 
                    variant="outlined" 
                  />
                  <Chip 
                    icon={<TrendingUpIcon />} 
                    label="Real-time Analytics" 
                    color="success" 
                    variant="outlined" 
                  />
                  <Chip 
                    icon={<AutoAwesomeIcon />} 
                    label="Smart Reports" 
                    color="primary" 
                    variant="outlined" 
                  />
                </Stack>
                
                <Box sx={{ display: 'flex', justifyContent: 'center', gap: 2 }}>
                  <Button
                    variant="contained"
                    size="large"
                    startIcon={<RocketLaunchIcon />}
                    sx={{ 
                      px: 4,
                      py: 1.5,
                      borderRadius: 2,
                      background: `linear-gradient(135deg, ${theme.palette.info.main} 0%, ${theme.palette.primary.main} 100%)`,
                      '&:hover': {
                        transform: 'translateY(-2px)',
                        boxShadow: `0 8px 25px ${alpha(theme.palette.info.main, 0.3)}`
                      }
                    }}
                  >
                    Coming Soon
                  </Button>
                  <Button
                    variant="outlined"
                    size="large"
                    startIcon={<DashboardIcon />}
                    onClick={() => setActiveTab(0)}
                    sx={{ 
                      px: 4,
                      py: 1.5,
                      borderRadius: 2
                    }}
                  >
                    View Dashboard
                  </Button>
                </Box>
              </Box>
              
              {/* Decorative elements */}
              <Box
                sx={{
                  position: 'absolute',
                  top: -80,
                  right: -80,
                  width: 200,
                  height: 200,
                  borderRadius: '50%',
                  background: `linear-gradient(135deg, ${alpha(theme.palette.info.main, 0.08)} 0%, ${alpha(theme.palette.primary.main, 0.04)} 100%)`,
                  zIndex: 0
                }}
              />
              <Box
                sx={{
                  position: 'absolute',
                  bottom: -60,
                  left: -60,
                  width: 150,
                  height: 150,
                  borderRadius: '50%',
                  background: `linear-gradient(135deg, ${alpha(theme.palette.primary.main, 0.06)} 0%, ${alpha(theme.palette.info.main, 0.03)} 100%)`,
                  zIndex: 0
                }}
              />
            </Paper>
          </Fade>
        </TabPanel>
        
        {/* Advanced Create Invoice Dialog */}
        <Dialog 
          open={createDialogOpen} 
          onClose={handleCancelCreate}
          maxWidth="xl"
          fullWidth
          PaperProps={{
            sx: { 
              height: '95vh',
              borderRadius: 3,
              boxShadow: `0 25px 50px ${alpha(theme.palette.primary.main, 0.15)}`,
              overflow: 'hidden'
            }
          }}
          TransitionComponent={Slide}
          TransitionProps={{ direction: 'up' } as any}
        >
          <DialogTitle sx={{ 
            background: `linear-gradient(135deg, ${theme.palette.primary.main} 0%, ${theme.palette.secondary.main} 100%)`,
            color: 'white',
            display: 'flex',
            alignItems: 'center',
            p: 3,
            position: 'relative',
            overflow: 'hidden'
          }}>
            <Box sx={{ display: 'flex', alignItems: 'center', position: 'relative', zIndex: 1 }}>
              <Avatar sx={{ bgcolor: 'rgba(255,255,255,0.2)', mr: 2, width: 48, height: 48 }}>
                <SparklesIcon sx={{ fontSize: 24 }} />
              </Avatar>
              <Box>
                <Typography variant="h5" fontWeight="bold">
                  Advanced Invoice Creation Wizard
                </Typography>
                <Typography variant="body2" sx={{ opacity: 0.9 }}>
                  Step-by-step guided creation with validation and templates
                </Typography>
              </Box>
            </Box>
            
            <IconButton
              aria-label="close"
              onClick={handleCancelCreate}
              sx={{
                position: 'absolute',
                right: 16,
                top: 16,
                color: 'white',
                bgcolor: 'rgba(255,255,255,0.1)',
                backdropFilter: 'blur(10px)',
                '&:hover': {
                  bgcolor: 'rgba(255,255,255,0.2)',
                  transform: 'scale(1.1)'
                }
              }}
            >
              <CloseIcon />
            </IconButton>
            
            {/* Decorative elements */}
            <Box
              sx={{
                position: 'absolute',
                top: -30,
                right: -30,
                width: 120,
                height: 120,
                borderRadius: '50%',
                background: 'rgba(255,255,255,0.1)',
                zIndex: 0
              }}
            />
          </DialogTitle>
          <DialogContent sx={{ p: 0, overflow: 'hidden' }}>
            <ModernInvoiceCreation
              type={invoiceType}
              onSave={handleSaveInvoice}
              onCancel={handleCancelCreate}
            />
          </DialogContent>
        </Dialog>
      </Container>
    </ImprovedDashboardLayout>
  );
}

export default function ModernInvoicesPage() {
  return (
    <ModernThemeProvider>
      <ModernDashboardLayout
        title="Invoices"
        subtitle="Manage your invoices and billing"
        showBreadcrumbs={true}
        showSearch={true}
        showQuickActions={true}
        pageHeaderActions={
          <Stack direction="row" spacing={2}>
            <Button
              variant="outlined"
              startIcon={<DownloadIcon />}
              sx={{ borderRadius: 2 }}
            >
              Export
            </Button>
            <Button
              variant="contained"
              startIcon={<AddIcon />}
              sx={{ borderRadius: 2 }}
            >
              Add New
            </Button>
          </Stack>
        }
      >
        <InvoicesPage />
      </ModernDashboardLayout>
    </ModernThemeProvider>
  );
}